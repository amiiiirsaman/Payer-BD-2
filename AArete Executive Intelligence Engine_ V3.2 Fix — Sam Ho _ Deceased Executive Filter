### Change 1 — Add `_is_known_deceased()` Python guard

After the `_employer_matches_payer` function (around line 555), add this new function:

```python
_DECEASED_SIGNALS: frozenset[str] = frozenset({
    "passed away", "has died", "have died", "died ", "death of",
    "obituary", "in memoriam", "rest in peace", "is survived by",
    "funeral", "memorial service", "posthumously",
})

def _is_known_deceased(name: str, evidence: list[Evidence]) -> bool:
    """Return True if any evidence item contains the candidate's last name
    alongside a deceased-signal phrase. Used as a Python-level guard after
    the LLM classification step to catch cases where the LLM missed the signal.
    """
    # Extract last name (last whitespace-delimited token, ignoring suffixes)
    _SUFFIXES = {"jr", "sr", "ii", "iii", "iv", "md", "phd", "do"}
    parts = [p.strip(".,") for p in name.lower().split()]
    last = next((p for p in reversed(parts) if p not in _SUFFIXES), None)
    if not last or len(last) < 3:
        return False
    for ev in evidence:
        text = ((ev.full_text or "") + " " + (ev.snippet or "")).lower()
        if last not in text:
            continue
        if any(sig in text for sig in _DECEASED_SIGNALS):
            return True
    return False
```

